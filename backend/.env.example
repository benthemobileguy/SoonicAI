# ===========================================
# Soonic AI Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ===========================================
# App Configuration
# ===========================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# ===========================================
# AI Service (FastAPI)
# ===========================================
# URL of your FastAPI AI service
AI_SERVICE_URL=http://localhost:8000

# ===========================================
# File Processing
# ===========================================
# Maximum video duration in seconds (300 = 5 minutes)
MAX_VIDEO_DURATION=300

# Temporary directory for downloaded files
TEMP_DIR=/tmp

# ===========================================
# Supabase (Database & Authentication)
# ===========================================
# Get these from: https://app.supabase.com
# Go to: Settings → API

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# IMPORTANT: Use SERVICE_KEY (not anon key) in backend
# The service key gives admin access to database
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ===========================================
# Stripe (Payment Processing)
# ===========================================
# Get these from: https://dashboard.stripe.com
# Go to: Developers → API Keys

# Secret key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Webhook secret (for webhook signature verification)
# Get from: Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Price IDs - Create these in Stripe Dashboard
# Pro Subscription (monthly, $19.90/month)
STRIPE_PRICE_SUBSCRIPTION=price_your-subscription-price-id

# Credit Packs (one-time payments)
STRIPE_PRICE_STARTER=price_starter_pack_id     # 5 credits for $9.90
STRIPE_PRICE_STANDARD=price_standard_pack_id   # 17 credits for $24.90
STRIPE_PRICE_PRO_PACK=price_pro_pack_id        # 40 credits for $49.90
